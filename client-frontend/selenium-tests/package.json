{
  "name": "bella-selenium-tests",
  "version": "1.0.0",
  "scripts": {
    "test": "jest bella.test.js --testTimeout=30000 --runInBand",
    "test:client": "jest bella.test.js --testTimeout=30000 --runInBand -t 'Client'",
    "test:admin": "jest bella.test.js --testTimeout=30000 --runInBand -t 'Admin'"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/bella.test.js"
    ]
  },
  "devDependencies": {
    "@types/selenium-webdriver": "^4.35.5",
    "jest": "^29.7.0"
  },
  "dependencies": {
    "chromedriver": "^145.0.6",
    "selenium-webdriver": "^4.41.0"
  }
}